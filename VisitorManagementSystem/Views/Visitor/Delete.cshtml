@model VisitorManagementSystem.Models.Visitor
@{
    ViewBag.Title = "Delete";
}

<style>
    .vd-wrap {
        max-width: 560px;
        margin: 2.5rem auto;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    /* header */
    .vd-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 2rem;
    }

    .vd-header-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #EF4444, #DC2626);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        box-shadow: 0 4px 14px rgba(239,68,68,0.35);
        flex-shrink: 0;
    }

    .vd-header-text h2 {
        font-size: 22px;
        font-weight: 800;
        color: #111827;
        margin: 0;
        letter-spacing: -0.4px;
    }

    .vd-header-text p {
        font-size: 13px;
        color: #6B7280;
        margin: 3px 0 0;
    }

    /* warning banner */
    .vd-warning {
        background: #FEF2F2;
        border: 1.5px solid #FECACA;
        border-radius: 14px;
        padding: 14px 18px;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1.75rem;
    }

    .vd-warning-icon {
        font-size: 20px;
        flex-shrink: 0;
    }

    .vd-warning-text {
        font-size: 13.5px;
        font-weight: 600;
        color: #B91C1C;
        margin: 0;
    }

    .vd-warning-sub {
        font-size: 12px;
        color: #EF4444;
        margin: 2px 0 0;
        font-weight: 400;
    }

    /* card */
    .vd-card {
        background: #fff;
        border-radius: 20px;
        border: 1px solid #E5E7EB;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }

    .vd-card-accent {
        height: 5px;
        background: linear-gradient(90deg, #EF4444, #F97316);
    }

    /* visitor identity */
    .vd-identity {
        padding: 1.5rem 1.75rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 14px;
        border-bottom: 1px solid #F3F4F6;
    }

    .vd-avatar {
        width: 52px;
        height: 52px;
        border-radius: 50%;
        background: #FEF2F2;
        color: #EF4444;
        font-size: 18px;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        text-transform: uppercase;
        border: 2px solid #FECACA;
    }

    .vd-identity-name {
        font-size: 17px;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .vd-identity-nic {
        font-size: 12px;
        color: #9CA3AF;
        margin: 3px 0 0;
        font-family: 'Courier New', monospace;
    }

    /* detail grid */
    .vd-details {
        padding: 1.25rem 1.75rem;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px 20px;
        border-bottom: 1px solid #F3F4F6;
    }

    .vd-detail-item {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .vd-detail-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: #9CA3AF;
    }

    .vd-detail-value {
        font-size: 13.5px;
        color: #374151;
        font-weight: 500;
    }

    /* footer */
    .vd-footer {
        background: #FFF5F5;
        border-top: 1px solid #FEE2E2;
        padding: 1.25rem 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .vd-back {
        font-size: 13px;
        color: #6B7280;
        text-decoration: none;
        font-weight: 500;
        transition: color 0.15s;
    }

        .vd-back:hover {
            color: #374151;
            text-decoration: none;
        }

    .vd-delete-btn {
        background: linear-gradient(135deg, #EF4444, #DC2626);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 26px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        letter-spacing: 0.01em;
        transition: opacity 0.15s, transform 0.1s, box-shadow 0.15s;
        box-shadow: 0 3px 12px rgba(239,68,68,0.3);
    }

        .vd-delete-btn:hover {
            opacity: 0.92;
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(239,68,68,0.35);
        }

        .vd-delete-btn:active {
            transform: scale(0.98);
        }

    @@media (max-width: 500px) {
        .vd-details {
            grid-template-columns: 1fr;
        }

        .vd-wrap {
            margin: 1rem;
        }
    }
</style>

<div class="vd-wrap">

    <div class="vd-header">
        <div class="vd-header-icon">🗑️</div>
        <div class="vd-header-text">
            <h2>Delete Visitor</h2>
            <p>Review the record before removing</p>
        </div>
    </div>

    <div class="vd-warning">
        <span class="vd-warning-icon">⚠️</span>
        <div>
            <p class="vd-warning-text">Are you sure you want to delete this visitor?</p>
            <p class="vd-warning-sub">This action cannot be undone.</p>
        </div>
    </div>

    <div class="vd-card">
        <div class="vd-card-accent"></div>

        @{
            var initials = string.IsNullOrEmpty(Model.FullName) ? "?" :
                string.Join("", Model.FullName.Split(' ').Take(2).Select(w => w[0]));
        }

        <div class="vd-identity">
            <div class="vd-avatar">@initials</div>
            <div>
                <p class="vd-identity-name">@Html.DisplayFor(model => model.FullName)</p>
                <p class="vd-identity-nic">@Html.DisplayFor(model => model.NIC)</p>
            </div>
        </div>

        <div class="vd-details">
            <div class="vd-detail-item">
                <span class="vd-detail-label">📞 @Html.DisplayNameFor(model => model.Phone)</span>
                <span class="vd-detail-value">@Html.DisplayFor(model => model.Phone)</span>
            </div>
            <div class="vd-detail-item">
                <span class="vd-detail-label">👤 @Html.DisplayNameFor(model => model.PersonToVisit)</span>
                <span class="vd-detail-value">@Html.DisplayFor(model => model.PersonToVisit)</span>
            </div>
            <div class="vd-detail-item" style="grid-column: 1 / -1;">
                <span class="vd-detail-label">🎯 @Html.DisplayNameFor(model => model.Purpose)</span>
                <span class="vd-detail-value">@Html.DisplayFor(model => model.Purpose)</span>
            </div>
            <div class="vd-detail-item">
                <span class="vd-detail-label">🟢 @Html.DisplayNameFor(model => model.CheckInTime)</span>
                <span class="vd-detail-value">@Html.DisplayFor(model => model.CheckInTime)</span>
            </div>
            <div class="vd-detail-item">
                <span class="vd-detail-label">🔴 @Html.DisplayNameFor(model => model.CheckOutTime)</span>
                <span class="vd-detail-value">@Html.DisplayFor(model => model.CheckOutTime)</span>
            </div>
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="vd-footer">
                @Html.ActionLink("← Back to List", "Index", null, new { @class = "vd-back" })
                <input type="submit" value="Yes, Delete" class="vd-delete-btn" />
            </div>
        }

    </div>
</div>
