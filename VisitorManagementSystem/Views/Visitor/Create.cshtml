@model VisitorManagementSystem.Models.Visitor

@{
    ViewBag.Title = "Create";
}

<style>
    .vcf-wrap {
        max-width: 680px;
        margin: 2.5rem auto;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    .vcf-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 2rem;
    }

    .vcf-header-icon {
        width: 48px;
        height: 48px;
        background: #EEF2FF;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        flex-shrink: 0;
    }

    .vcf-header-text h2 {
        font-size: 22px;
        font-weight: 700;
        color: #111827;
        margin: 0;
    }

    .vcf-header-text p {
        font-size: 13px;
        color: #6B7280;
        margin: 3px 0 0;
    }

    .vcf-card {
        background: #fff;
        border-radius: 18px;
        border: 1px solid #E5E7EB;
        overflow: hidden;
    }

    .vcf-section {
        padding: 1.5rem 1.75rem;
    }

        .vcf-section + .vcf-section {
            border-top: 1px solid #F3F4F6;
        }

    .vcf-section-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #9CA3AF;
        margin: 0 0 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .vcf-section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #F3F4F6;
        }

    .vcf-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

        .vcf-row.full {
            grid-template-columns: 1fr;
        }

    .vcf-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .vcf-field label {
            font-size: 13px;
            font-weight: 600;
            color: #374151;
        }

        .vcf-field .form-control,
        .vcf-field select.form-control {
            border: 1.5px solid #E5E7EB;
            border-radius: 10px;
            padding: 10px 14px;
            font-size: 14px;
            color: #111827;
            background: #F9FAFB;
            transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
            width: 100%;
            box-sizing: border-box;
            outline: none;
            -webkit-appearance: none;
        }

            .vcf-field .form-control:focus,
            .vcf-field select.form-control:focus {
                border-color: #6366F1;
                background: #fff;
                box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
            }

        .vcf-field .text-danger {
            font-size: 12px;
            color: #EF4444;
            margin: 0;
        }

        .vcf-field .field-icon {
            position: relative;
        }

    .vcf-footer {
        background: #F9FAFB;
        border-top: 1px solid #E5E7EB;
        padding: 1.25rem 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .btn-back {
        font-size: 13px;
        color: #6B7280;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 500;
        transition: color 0.15s;
    }

        .btn-back:hover {
            color: #374151;
            text-decoration: none;
        }

    .btn-create {
        background: #4F46E5;
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 28px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s, transform 0.1s;
        letter-spacing: 0.01em;
    }

        .btn-create:hover {
            background: #4338CA;
        }

        .btn-create:active {
            transform: scale(0.98);
        }

    .validation-summary-errors {
        background: #FEF2F2;
        border: 1px solid #FECACA;
        border-radius: 10px;
        padding: 12px 16px;
        margin-bottom: 1.25rem;
        color: #B91C1C;
        font-size: 13px;
    }

    .status-select-wrap {
        position: relative;
    }

        .status-select-wrap::after {
            content: '▾';
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #9CA3AF;
            pointer-events: none;
            font-size: 12px;
        }

    @@media (max-width: 600px) {
        .vcf-row {
            grid-template-columns: 1fr;
        }

        .vcf-wrap {
            margin: 1rem;
        }
    }
</style>

<div class="vcf-wrap">

    <div class="vcf-header">
        <div class="vcf-header-icon">🪪</div>
        <div class="vcf-header-text">
            <h2>Register New Visitor</h2>
            <p>Fill in the details below to check in a visitor</p>
        </div>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="vcf-card">

            @* Personal Info *@
            <div class="vcf-section">
                <p class="vcf-section-title">Personal Info</p>
                @Html.ValidationSummary(true, "", new { @class = "validation-summary-errors" })

                <div class="vcf-row">
                    <div class="vcf-field">
                        @Html.LabelFor(model => model.FullName)
                        @Html.EditorFor(model => model.FullName, new { htmlAttributes = new { @class = "form-control", placeholder = "e.g. Kamal Perera" } })
                        @Html.ValidationMessageFor(model => model.FullName, "", new { @class = "text-danger" })
                    </div>
                    <div class="form-group">
                        @Html.LabelFor(model => model.NIC)

                        @Html.EditorFor(model => model.NIC,
                                new { htmlAttributes = new { @class = "form-control" } })

                        @Html.ValidationMessageFor(model => model.NIC,
                                "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="vcf-row" style="margin-top:16px;">
                    <div class="vcf-field">
                        @Html.LabelFor(model => model.Phone)
                        @Html.EditorFor(model => model.Phone, new { htmlAttributes = new { @class = "form-control", placeholder = "e.g. 071 234 5678" } })
                        @Html.ValidationMessageFor(model => model.Phone, "", new { @class = "text-danger" })
                    </div>
                    <div class="vcf-field">
                        @Html.LabelFor(model => model.PersonToVisit)
                        @Html.EditorFor(model => model.PersonToVisit, new { htmlAttributes = new { @class = "form-control", placeholder = "Who are they visiting?" } })
                        @Html.ValidationMessageFor(model => model.PersonToVisit, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            @* Visit Details *@
            <div class="vcf-section">
                <p class="vcf-section-title">Visit Details</p>

                <div class="vcf-row full">
                    <div class="vcf-field">
                        @Html.LabelFor(model => model.Purpose)
                        @Html.EditorFor(model => model.Purpose, new { htmlAttributes = new { @class = "form-control", placeholder = "e.g. Meeting with HR department" } })
                        @Html.ValidationMessageFor(model => model.Purpose, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="vcf-row" style="margin-top:16px;">
                    <div class="vcf-field">
                        @Html.LabelFor(model => model.CheckInTime)
                        @Html.EditorFor(model => model.CheckInTime, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.CheckInTime, "", new { @class = "text-danger" })
                    </div>
                    <div class="vcf-field">
                        @Html.LabelFor(model => model.CheckOutTime)
                        @Html.EditorFor(model => model.CheckOutTime, new { htmlAttributes = new { @class = "form-control" } })
                        @Html.ValidationMessageFor(model => model.CheckOutTime, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            @* Status *@
            <div class="vcf-section">
                <p class="vcf-section-title">Status</p>
                <div class="vcf-row">
                    <div class="vcf-field">
                        @Html.LabelFor(model => model.Status)
                        <div class="status-select-wrap">
                            @Html.DropDownListFor(model => model.Status,
                                    new SelectList(new[]
                                    {
                                   "Checked In",
                                   "Checked Out"
                        }),
                                    "Select Status",
                                    new { @class = "form-control" })
                        </div>
                    </div>
                </div>
            </div>

            @* Footer *@
            <div class="vcf-footer">
                @Html.ActionLink("← Back to List", "Index", null, new { @class = "btn-back" })
                <input type="submit" value="Register Visitor" class="btn-create" />
            </div>

        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
