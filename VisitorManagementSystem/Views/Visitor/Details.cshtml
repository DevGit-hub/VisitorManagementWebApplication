@model VisitorManagementSystem.Models.Visitor
@{
    ViewBag.Title = "Details";
}

<style>
    .vdt-wrap {
        max-width: 560px;
        margin: 2.5rem auto;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    /* header */
    .vdt-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 2rem;
    }

    .vdt-header-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #0891B2, #6366F1);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        box-shadow: 0 4px 14px rgba(99,102,241,0.3);
        flex-shrink: 0;
    }

    .vdt-header-text h2 {
        font-size: 22px;
        font-weight: 800;
        color: #111827;
        margin: 0;
        letter-spacing: -0.4px;
    }

    .vdt-header-text p {
        font-size: 13px;
        color: #6B7280;
        margin: 3px 0 0;
    }

    /* card */
    .vdt-card {
        background: #fff;
        border-radius: 20px;
        border: 1px solid #E5E7EB;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }

    .vdt-card-accent {
        height: 5px;
        background: linear-gradient(90deg, #0891B2, #6366F1, #8B5CF6);
    }

    /* identity block */
    .vdt-identity {
        padding: 1.5rem 1.75rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 16px;
        border-bottom: 1px solid #F3F4F6;
        background: linear-gradient(135deg, #F0F9FF 0%, #EEF2FF 100%);
    }

    .vdt-avatar {
        width: 58px;
        height: 58px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6366F1, #8B5CF6);
        color: #fff;
        font-size: 20px;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        text-transform: uppercase;
        box-shadow: 0 4px 14px rgba(99,102,241,0.35);
    }

    .vdt-identity-name {
        font-size: 18px;
        font-weight: 800;
        color: #111827;
        margin: 0;
        letter-spacing: -0.3px;
    }

    .vdt-identity-nic {
        font-size: 12px;
        color: #6B7280;
        margin: 4px 0 0;
        font-family: 'Courier New', monospace;
        background: #E0E7FF;
        color: #4338CA;
        padding: 2px 8px;
        border-radius: 6px;
        display: inline-block;
        font-weight: 600;
    }

    /* section title */
    .vdt-section {
        padding: 1.25rem 1.75rem;
    }

        .vdt-section + .vdt-section {
            border-top: 1px solid #F3F4F6;
        }

    .vdt-section-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #9CA3AF;
        margin: 0 0 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .vdt-section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #F3F4F6;
        }

    /* detail grid */
    .vdt-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px 20px;
    }

    .vdt-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .vdt-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: #9CA3AF;
    }

    .vdt-value {
        font-size: 14px;
        color: #111827;
        font-weight: 500;
    }

    .vdt-value-mono {
        font-family: 'Courier New', monospace;
        font-size: 13px;
        color: #374151;
    }

    /* footer */
    .vdt-footer {
        background: #F9FAFB;
        border-top: 1px solid #E5E7EB;
        padding: 1.25rem 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .vdt-back {
        font-size: 13px;
        color: #6B7280;
        text-decoration: none;
        font-weight: 500;
        transition: color 0.15s;
    }

        .vdt-back:hover {
            color: #374151;
            text-decoration: none;
        }

    .vdt-edit-btn {
        background: linear-gradient(135deg, #6366F1, #8B5CF6);
        color: #fff !important;
        text-decoration: none !important;
        border-radius: 10px;
        padding: 10px 24px;
        font-size: 13px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: opacity 0.15s, transform 0.1s, box-shadow 0.15s;
        box-shadow: 0 3px 12px rgba(99,102,241,0.3);
    }

        .vdt-edit-btn:hover {
            opacity: 0.92;
            transform: translateY(-1px);
            box-shadow: 0 6px 18px rgba(99,102,241,0.35);
            text-decoration: none !important;
        }

        .vdt-edit-btn:active {
            transform: scale(0.98);
        }

    @@media (max-width: 500px) {
        .vdt-grid {
            grid-template-columns: 1fr;
        }

        .vdt-wrap {
            margin: 1rem;
        }
    }
</style>

<div class="vdt-wrap">

    <div class="vdt-header">
        <div class="vdt-header-icon">🪪</div>
        <div class="vdt-header-text">
            <h2>Visitor Details</h2>
            <p>Full record for this visitor</p>
        </div>
    </div>

    <div class="vdt-card">
        <div class="vdt-card-accent"></div>

        @{
            var initials = string.IsNullOrEmpty(Model.FullName) ? "?" :
                string.Join("", Model.FullName.Split(' ').Take(2).Select(w => w[0]));
        }

        <!-- Identity -->
        <div class="vdt-identity">
            <div class="vdt-avatar">@initials</div>
            <div>
                <p class="vdt-identity-name">@Html.DisplayFor(model => model.FullName)</p>
                <span class="vdt-identity-nic">@Html.DisplayFor(model => model.NIC)</span>
            </div>
        </div>

        <!-- Contact & Visit -->
        <div class="vdt-section">
            <p class="vdt-section-title">Contact &amp; Visit</p>
            <div class="vdt-grid">
                <div class="vdt-item">
                    <span class="vdt-label">📞 @Html.DisplayNameFor(model => model.Phone)</span>
                    <span class="vdt-value">@Html.DisplayFor(model => model.Phone)</span>
                </div>
                <div class="vdt-item">
                    <span class="vdt-label">👤 @Html.DisplayNameFor(model => model.PersonToVisit)</span>
                    <span class="vdt-value">@Html.DisplayFor(model => model.PersonToVisit)</span>
                </div>
                <div class="vdt-item" style="grid-column: 1 / -1;">
                    <span class="vdt-label">🎯 @Html.DisplayNameFor(model => model.Purpose)</span>
                    <span class="vdt-value">@Html.DisplayFor(model => model.Purpose)</span>
                </div>
            </div>
        </div>

        <!-- Timing -->
        <div class="vdt-section">
            <p class="vdt-section-title">Timing</p>
            <div class="vdt-grid">
                <div class="vdt-item">
                    <span class="vdt-label">🟢 @Html.DisplayNameFor(model => model.CheckInTime)</span>
                    <span class="vdt-value vdt-value-mono">@Html.DisplayFor(model => model.CheckInTime)</span>
                </div>
                <div class="vdt-item">
                    <span class="vdt-label">🔴 @Html.DisplayNameFor(model => model.CheckOutTime)</span>
                    <span class="vdt-value vdt-value-mono">@Html.DisplayFor(model => model.CheckOutTime)</span>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="vdt-footer">
            @Html.ActionLink("← Back to List", "Index", null, new { @class = "vdt-back" })
            @Html.ActionLink("✏️ Edit", "Edit", new { id = Model.VisitorID }, new { @class = "vdt-edit-btn" })
        </div>

    </div>
</div>
