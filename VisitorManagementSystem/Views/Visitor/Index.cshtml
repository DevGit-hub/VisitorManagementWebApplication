@model IEnumerable<VisitorManagementSystem.Models.Visitor>
@{
    ViewBag.Title = "Index";
}

<style>
    .vc-wrap {
        padding: 2rem 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    /* ── Top bar ── */
    .vc-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 1.75rem;
    }

    .vc-brand {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .vc-brand-icon {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #6366F1, #8B5CF6);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        box-shadow: 0 4px 14px rgba(99,102,241,0.3);
    }

    .vc-brand-title {
        font-size: 22px;
        font-weight: 800;
        color: #111827;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .vc-brand-sub {
        font-size: 13px;
        color: #6B7280;
        margin: 2px 0 0;
    }

    .vc-btn-new {
        background: #4F46E5;
        color: #fff !important;
        text-decoration: none !important;
        padding: 10px 22px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.02em;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
        box-shadow: 0 2px 8px rgba(79,70,229,0.25);
    }

        .vc-btn-new:hover {
            background: #4338CA;
            box-shadow: 0 4px 16px rgba(79,70,229,0.35);
            transform: translateY(-1px);
        }

    /* ── Search ── */
    .vc-search-wrap {
        margin-bottom: 1.75rem;
    }

    .vc-search-inner {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: #fff;
        border: 1.5px solid #E5E7EB;
        border-radius: 14px;
        padding: 9px 16px;
        min-width: 340px;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

        .vc-search-inner:focus-within {
            border-color: #6366F1;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
        }

    .vc-search-icon {
        font-size: 15px;
        color: #9CA3AF;
    }

    .vc-search-input {
        border: none;
        outline: none;
        background: transparent;
        font-size: 14px;
        color: #111827;
        flex: 1;
    }

    .vc-search-btn {
        background: #4F46E5;
        color: #fff;
        border: none;
        border-radius: 9px;
        padding: 6px 18px;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.15s;
    }

        .vc-search-btn:hover {
            background: #4338CA;
        }

    /* ── Table ── */
    .vc-table-wrap {
        background: #fff;
        border-radius: 18px;
        border: 1px solid #E5E7EB;
        overflow-x: auto;
        overflow-y: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    }

    .vc-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13.5px;
    }

        .vc-table thead tr {
            background: #F9FAFB;
            border-bottom: 1.5px solid #E5E7EB;
        }

        .vc-table thead th {
            padding: 13px 16px;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 0.07em;
            text-transform: uppercase;
            color: #9CA3AF;
            text-align: left;
            white-space: nowrap;
        }

        .vc-table tbody tr {
            border-bottom: 1px solid #F3F4F6;
            transition: background 0.1s;
        }

            .vc-table tbody tr:last-child {
                border-bottom: none;
            }

            .vc-table tbody tr:hover {
                background: #FAFAFA;
            }

        .vc-table tbody td {
            padding: 13px 16px;
            color: #374151;
            vertical-align: middle;
        }

    /* name cell with avatar */
    .vc-name-cell {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .vc-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #EEF2FF;
        color: #4F46E5;
        font-size: 12px;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        text-transform: uppercase;
        border: 2px solid #E0E7FF;
    }

    .vc-name-main {
        font-weight: 600;
        color: #111827;
        font-size: 13.5px;
    }

    .vc-name-sub {
        font-size: 11px;
        color: #9CA3AF;
        font-family: 'Courier New', monospace;
    }

    /* status badge */
    .vc-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 11px;
        border-radius: 100px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.04em;
        white-space: nowrap;
    }

    .vc-badge-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
    }

    .badge-in {
        background: #D1FAE5;
        color: #065F46;
    }

        .badge-in .vc-badge-dot {
            background: #10B981;
            animation: pulse-green 1.8s infinite;
        }

    .badge-out {
        background: #F3F4F6;
        color: #6B7280;
    }

        .badge-out .vc-badge-dot {
            background: #9CA3AF;
        }

    @@keyframes pulse-green {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.4;
        }
    }

    /* action buttons */
    .vc-actions {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .vc-act {
        padding: 5px 13px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 700;
        text-decoration: none;
        transition: background 0.12s, color 0.12s;
        white-space: nowrap;
    }

        .vc-act:hover {
            text-decoration: none;
        }

    .act-edit {
        color: #4F46E5;
        background: #EEF2FF;
    }

        .act-edit:hover {
            background: #E0E7FF;
        }

    .act-details {
        color: #0891B2;
        background: #E0F2FE;
    }

        .act-details:hover {
            background: #BAE6FD;
        }

    .act-delete {
        color: #DC2626;
        background: #FEF2F2;
    }

        .act-delete:hover {
            background: #FEE2E2;
        }

    /* empty state */
    .vc-empty {
        text-align: center;
        padding: 3.5rem 1rem;
        color: #9CA3AF;
    }

    .vc-empty-emoji {
        font-size: 40px;
        margin-bottom: 10px;
    }

    .vc-empty-text {
        font-size: 14px;
        font-weight: 500;
        margin: 0;
    }

    .vc-empty-sub {
        font-size: 13px;
        margin: 6px 0 0;
    }

    @@media (max-width: 900px) {
        .vc-table thead th:nth-child(n+5),
        .vc-table tbody td:nth-child(n+5) {
            display: none;
        }
    }

    @@media (max-width: 560px) {
        .vc-search-inner {
            min-width: 100%;
            width: 100%;
        }
    }
</style>

<div class="vc-wrap">

    <!-- Top bar -->
    <div class="vc-topbar">
        <div class="vc-brand">
            <div class="vc-brand-icon">🪪</div>
            <div>
                <p class="vc-brand-title">Visitor Log</p>
                <p class="vc-brand-sub">All registered visitors</p>
            </div>
        </div>
        @Html.ActionLink("＋ Register Visitor", "Create", null, new { @class = "vc-btn-new" })
    </div>

    <!-- Search -->
    @using (Html.BeginForm("Index", "Visitor", FormMethod.Get))
    {
        <div class="vc-search-wrap">
            <div class="vc-search-inner">
                <span class="vc-search-icon">🔍</span>
                @Html.TextBox("searchString", null, new { placeholder = "Search visitors…", @class = "vc-search-input" })
                <input type="submit" value="Search" class="vc-search-btn" />
            </div>
        </div>
    }

    <!-- Table -->
    <div class="vc-table-wrap">
        <table class="vc-table">
            <thead>
                <tr>
                    <th>@Html.DisplayNameFor(model => model.FullName)</th>
                    <th>@Html.DisplayNameFor(model => model.Phone)</th>
                    <th>@Html.DisplayNameFor(model => model.Purpose)</th>
                    <th>@Html.DisplayNameFor(model => model.PersonToVisit)</th>
                    <th>@Html.DisplayNameFor(model => model.CheckInTime)</th>
                    <th>@Html.DisplayNameFor(model => model.CheckOutTime)</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8">
                            <div class="vc-empty">
                                <div class="vc-empty-emoji">🏢</div>
                                <p class="vc-empty-text">No visitors yet</p>
                                <p class="vc-empty-sub">Register the first visitor to get started.</p>
                            </div>
                        </td>
                    </tr>
                }

                @foreach (var item in Model)
                {
                    var initials = string.IsNullOrEmpty(item.FullName) ? "?" :
                        string.Join("", item.FullName.Split(' ').Take(2).Select(w => w[0]));
                    var isIn = item.Status == "Checked In";

                    <tr>
                        <td>
                            <div class="vc-name-cell">
                                <div class="vc-avatar">@initials</div>
                                <div>
                                    <div class="vc-name-main">@Html.DisplayFor(modelItem => item.FullName)</div>
                                    <div class="vc-name-sub">@Html.DisplayFor(modelItem => item.NIC)</div>
                                </div>
                            </div>
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.Phone)</td>
                        <td>@Html.DisplayFor(modelItem => item.Purpose)</td>
                        <td>@Html.DisplayFor(modelItem => item.PersonToVisit)</td>
                        <td>
                            @item.CheckInTime.ToString("dd/MM/yyyy HH:mm:ss")
                        </td>
                        <td>
                            @if (item.CheckOutTime != null)
                            {
                                @item.CheckOutTime.Value.ToString("dd/MM/yyyy HH:mm:ss")
                            }
                            else
                            {
                                <span>Not Checked Out</span>
                            }
                        </td>
                        <td>
                            <span class="vc-badge @(isIn ? "badge-in" : "badge-out")">
                                <span class="vc-badge-dot"></span>
                                @item.Status
                            </span>
                        </td>
                        <td>
                            <div class="vc-actions">

                                @if (item.CheckOutTime == null)
                                {
                                    @Html.ActionLink(
                                             "Check Out",
                                             "CheckOut",
                                             new { id = item.VisitorID },
                                             new { @class = "vc-act act-details" }
                                         )
                                }

                                @Html.ActionLink(
                                        "Edit",
                                        "Edit",
                                        new { id = item.VisitorID },
                                        new { @class = "vc-act act-edit" }
                                    )

                                @Html.ActionLink(
                                        "Details",
                                        "Details",
                                        new { id = item.VisitorID },
                                        new { @class = "vc-act act-details" }
                                    )

                                @Html.ActionLink(
                                        "Delete",
                                        "Delete",
                                        new { id = item.VisitorID },
                                        new { @class = "vc-act act-delete" }
                                    )

                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>
