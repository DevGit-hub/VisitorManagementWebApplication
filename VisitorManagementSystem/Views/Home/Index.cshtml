@{
    ViewBag.Title = "Home Page";
}

<style>
    .vmd-wrap {
        padding: 2.5rem 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    .vmd-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 2rem;
    }

    .vmd-header-icon {
        width: 44px;
        height: 44px;
        background: #EEF2FF;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
    }

    .vmd-header-text h2 {
        font-size: 22px;
        font-weight: 600;
        color: #111827;
        margin: 0;
    }

    .vmd-header-text p {
        font-size: 13px;
        color: #6B7280;
        margin: 2px 0 0;
    }

    .vmd-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
    }

    .vmd-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #E5E7EB;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: box-shadow 0.2s ease, transform 0.2s ease;
    }

        .vmd-card:hover {
            box-shadow: 0 8px 24px rgba(0,0,0,0.08);
            transform: translateY(-2px);
        }

    .vmd-card-glow {
        position: absolute;
        top: -30px;
        right: -30px;
        width: 100px;
        height: 100px;
        border-radius: 50%;
        opacity: 0.12;
        pointer-events: none;
    }

    .card-blue .vmd-card-glow {
        background: #3B82F6;
    }

    .card-teal .vmd-card-glow {
        background: #10B981;
    }

    .card-amber .vmd-card-glow {
        background: #F59E0B;
    }

    .vmd-card-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
    }

    .vmd-card-badge {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        padding: 3px 10px;
        border-radius: 100px;
    }

    .card-blue .vmd-card-badge {
        background: #DBEAFE;
        color: #1D4ED8;
    }

    .card-teal .vmd-card-badge {
        background: #D1FAE5;
        color: #065F46;
    }

    .card-amber .vmd-card-badge {
        background: #FEF3C7;
        color: #92400E;
    }

    .vmd-icon-circle {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    .card-blue .vmd-icon-circle {
        background: #EFF6FF;
    }

    .card-teal .vmd-icon-circle {
        background: #ECFDF5;
    }

    .card-amber .vmd-icon-circle {
        background: #FFFBEB;
    }

    .vmd-card-label {
        font-size: 13px;
        font-weight: 500;
        color: #6B7280;
        margin: 0 0 6px;
    }

    .vmd-card-value {
        font-size: 40px;
        font-weight: 700;
        line-height: 1;
        margin: 0 0 8px;
        letter-spacing: -1px;
    }

    .card-blue .vmd-card-value {
        color: #1D4ED8;
    }

    .card-teal .vmd-card-value {
        color: #047857;
    }

    .card-amber .vmd-card-value {
        color: #B45309;
    }

    .vmd-card-divider {
        height: 1px;
        background: #F3F4F6;
        margin: 12px 0;
    }

    .vmd-card-meta {
        font-size: 12px;
        color: #9CA3AF;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .vmd-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        display: inline-block;
    }

    .card-blue .vmd-dot {
        background: #3B82F6;
    }

    .card-teal .vmd-dot {
        background: #10B981;
    }

    .card-amber .vmd-dot {
        background: #F59E0B;
    }

    @@media (max-width: 768px) {
        .vmd-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<main>
    <div class="vmd-wrap">

       <div class="vmd-header">
            <div class="vmd-header-icon">🏢</div>
            <div class="vmd-header-text">
                <h2>Visitor Management Dashboard</h2>
                <p>Real-time access overview · Updated just now</p>
            </div>
        </div>

       <div class="vmd-grid">

           <!-- Total Visitors -->
           <div class="vmd-card card-blue">
               <div class="vmd-card-glow"></div>
               <div class="vmd-card-top">
                   <div class="vmd-icon-circle">👥</div>
                   <span class="vmd-card-badge">All Time</span>
               </div>
               <p class="vmd-card-label">Total Visitors</p>
               <h2 class="vmd-card-value">@ViewBag.TotalVisitors</h2>
               <div class="vmd-card-divider"></div>
               <div class="vmd-card-meta">
                   <span class="vmd-dot"></span>
                   Cumulative records
               </div>
           </div>

           <!-- Today's Visitors -->
           <div class="vmd-card card-teal">
               <div class="vmd-card-glow"></div>
               <div class="vmd-card-top">
                   <div class="vmd-icon-circle">📅</div>
                   <span class="vmd-card-badge">Today</span>
               </div>
               <p class="vmd-card-label">Today's Visitors</p>
               <h2 class="vmd-card-value">@ViewBag.TodayVisitors</h2>
               <div class="vmd-card-divider"></div>
               <div class="vmd-card-meta">
                   <span class="vmd-dot"></span>
                   Since midnight
               </div>
           </div>

           <!-- Currently Inside -->
           <div class="vmd-card card-amber">
               <div class="vmd-card-glow"></div>
               <div class="vmd-card-top">
                   <div class="vmd-icon-circle">🚪</div>
                   <span class="vmd-card-badge">Live</span>
               </div>
               <p class="vmd-card-label">Currently Inside</p>
               <h2 class="vmd-card-value">@ViewBag.CurrentVisitors</h2>
               <div class="vmd-card-divider"></div>
               <div class="vmd-card-meta">
                   <span class="vmd-dot"></span>
                   On premises now
               </div>
           </div>

           <!--yersterday -->
           <div class="vmd-card card-blue">
               <div class="vmd-card-glow"></div>

               <div class="vmd-card-top">
                   <div class="vmd-icon-circle">📅</div>
                   <span class="vmd-card-badge">Yesterday</span>
               </div>

               <p class="vmd-card-label">Yesterday Visitors</p>
               <h2 class="vmd-card-value">@ViewBag.YesterdayVisitors</h2>

               <div class="vmd-card-divider"></div>

               <div class="vmd-card-meta">
                   <span class="vmd-dot"></span>
                   Previous day records
               </div>
           </div>

           <!-- This month -->
           <div class="vmd-card card-teal">
               <div class="vmd-card-glow"></div>

               <div class="vmd-card-top">
                   <div class="vmd-icon-circle">📆</div>
                   <span class="vmd-card-badge">Monthly</span>
               </div>

               <p class="vmd-card-label">This Month Visitors</p>
               <h2 class="vmd-card-value">@ViewBag.MonthVisitors</h2>

               <div class="vmd-card-divider"></div>

               <div class="vmd-card-meta">
                   <span class="vmd-dot"></span>
                   Monthly total
               </div>
           </div>

           <!-- This Year -->
           <div class="vmd-card card-amber">
               <div class="vmd-card-glow"></div>

               <div class="vmd-card-top">
                   <div class="vmd-icon-circle">📊</div>
                   <span class="vmd-card-badge">Yearly</span>
               </div>

               <p class="vmd-card-label">This Year Visitors</p>
               <h2 class="vmd-card-value">@ViewBag.YearVisitors</h2>

               <div class="vmd-card-divider"></div>

               <div class="vmd-card-meta">
                   <span class="vmd-dot"></span>
                   Yearly statistics
               </div>
           </div>

       </div>
    </div>
</main>
