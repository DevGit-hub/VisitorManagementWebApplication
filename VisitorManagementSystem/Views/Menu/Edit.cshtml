@model VisitorManagementSystem.Models.Menu

<h2>Edit Menu</h2>

@using (Html.BeginForm())
{

    @Html.HiddenFor(m => m.MenuId)

    <div class="form-group">
        <label>Display Name</label>
        @Html.TextBoxFor(m => m.DisplayName,
            new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label>Controller</label>
        @Html.TextBoxFor(m => m.Controller,
            new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label>Action</label>
        @Html.TextBoxFor(m => m.Action,
            new { @class = "form-control" })
    </div>

    <div class="form-group">
        <label>Parent Menu</label>

        @Html.DropDownListFor(
            m => m.ParentMenuId,
            new SelectList(
                ViewBag.ParentMenus,
                "MenuId",
                "DisplayName"
            ),
            "-- Select Parent --",
            new { @class = "form-control" }
        )
    </div>

    <br />

    <button type="submit"
            class="btn btn-primary">
        Update
    </button>

    @Html.ActionLink(
        "Back",
        "Index",
        null,
        new { @class = "btn btn-secondary" })
}