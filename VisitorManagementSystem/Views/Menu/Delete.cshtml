@model VisitorManagementSystem.Models.Menu

<h2>Delete Menu</h2>

<h4>
    Are you sure you want to delete this menu?
</h4>

<hr />

<dl class="dl-horizontal">

    <dt>Display Name</dt>
    <dd>@Model.DisplayName</dd>

    <dt>Controller</dt>
    <dd>@Model.Controller</dd>

    <dt>Action</dt>
    <dd>@Model.Action</dd>

</dl>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.MenuId)

    <button type="submit"
            class="btn btn-danger">
        Delete
    </button>

    @Html.ActionLink(
        "Cancel",
        "Index",
        null,
        new { @class = "btn btn-secondary" })
}